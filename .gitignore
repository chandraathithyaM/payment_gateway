# ==========================================
# Frontend (React, Vite, Node.js)
# ==========================================
# Dependencies
frontend/node_modules/
node_modules/

# Production build output
frontend/dist/
frontend/dist-ssr/
*-env.d.ts

# API keys and environment variables (NEVER COMMIT THESE)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env
frontend/.env.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================
# Backend (Java, Spring Boot, Maven)
# ==========================================
# Compiled class files and build artifacts
backend/target/
target/
*.class

# Package Files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Specific Spring Boot / Secrets
# (If you decide to split your properties, you can ignore the secret ones)
*application-secret.properties
*application-dev.properties

# ==========================================
# IDEs and Editors
# ==========================================
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# Eclipse
.metadata
.classpath
.project
.settings/
*.launch
bin/

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ==========================================
# System Files
# ==========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon

# Windows
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/
